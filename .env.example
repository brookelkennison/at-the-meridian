# Public site URL — used for absolute links and the social share image.
# In production set this to your live domain, e.g. https://atthemeridian.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (discovery call + confirmation emails) ───
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where lead notifications are sent
LEAD_TO_EMAIL=brooke@atthemeridian.co

# From address — must be a verified domain in Resend.
# To start fast, use Resend's onboarding sender: "At The Meridian <onboarding@resend.dev>"
LEAD_FROM_EMAIL=At The Meridian <onboarding@resend.dev>
